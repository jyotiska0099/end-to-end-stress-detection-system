# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=stress_user
POSTGRES_PASSWORD=stress_pass
POSTGRES_DB=stress_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://stress_user:stress_pass@postgres:5432/stress_db

# ── MinIO (S3-compatible MLflow artifact store) ──────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_NAME=stress-cnn-lstm
MLFLOW_MODEL_STAGE=Production

# ── Service ports (Docker Compose / local dev) ────────────────────────────────
INFERENCE_SERVICE_PORT=8000
LLM_SERVICE_PORT=8001
RESPONSE_ROUTER_PORT=8002

# ── Inference service ─────────────────────────────────────────────────────────
LLM_SERVICE_URL=http://llm-service:8001
RESPONSE_ROUTER_URL=http://response-router:8002

# ── Sensor simulator ─────────────────────────────────────────────────────────
NUM_PATIENTS=3
INFERENCE_URL=http://inference-service:8000/predict
SIGNAL_INTERVAL_SECONDS=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
